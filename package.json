{
  "name": "rfd-fyi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vite",
    "preview": "vite preview",
    "build": "vite build",
    "pages:dev": "npm run build && wrangler pages dev dist --kv TOPICS_KV --binding REFRESH_SECRET=dev",
    "pages:deploy": "npm run build && wrangler pages deploy dist",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "test": "npx vitest run",
    "test:coverage": "npx vitest run --coverage",
    "lint": "npx --yes oxlint"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "dayjs": "^1.11.10",
    "vue": "^3.5.17",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260621.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "jsdom": "^29.0.0",
    "oxlint": "^1.71.0",
    "terser": "^5.48.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "wrangler": "^4.103.0"
  }
}
