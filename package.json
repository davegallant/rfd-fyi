{
  "name": "rfd-fyi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "serve": "vite",
    "preview": "vite preview",
    "build": "vite build",
    "pages:dev": "npm run build && wrangler pages dev dist --kv TOPICS_KV --binding REFRESH_SECRET=dev",
    "pages:deploy": "npm run build && wrangler pages deploy dist",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "test": "npx vitest run",
    "test:coverage": "npx vitest run --coverage",
    "lint": "npx --yes oxlint"
  },
  "dependencies": {
    "@fontsource/roboto": "5.2.10",
    "@github/hotkey": "^3.0.0",
    "@mdi/font": "7.4.47",
    "@popperjs/core": "^2.11.8",
    "axios": "^1.15.0",
    "core-js": "^3.32.1",
    "cssnano": "^8.0.0",
    "dayjs": "^1.11.10",
    "oxlint": "^1.60.0",
    "vue": "^3.5.17",
    "vue-loading-overlay": "^6.0.3",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.6",
    "@cloudflare/workers-types": "^4.20260621.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "@vue/cli-plugin-babel": "~5.0.0",
    "@vue/cli-service": "^5.0.9",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.0",
    "postcss-cli": "^11.0.0",
    "sass-embedded": "^1.89.2",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "wrangler": "^4.103.0"
  }
}
